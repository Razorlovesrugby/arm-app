\cb3 export default function Layout() \{\cb1 \
\cb3   const [sidebarOpen, setSidebarOpen] = useState(false)\cb1 \
\cb3   const \{ clubSettings \} = useClubSettings()\cb1 \
\
\cb3   return (\cb1 \
\cb3     <div className="flex flex-col h-[100dvh] bg-gray-50">\cb1 \
\cb3       \{/* Sidebar (handles its own overlay on mobile) */\}\cb1 \
\cb3       <Sidebar isOpen=\{sidebarOpen\} onClose=\{() => setSidebarOpen(false)\} />\cb1 \
\
\cb3       \{/* Main content */\}\cb1 \
\cb3       <div className="flex-1 flex flex-col overflow-hidden">\cb1 \
\cb3         \{/* Mobile header */\}\cb1 \
\cb3         <header\cb1 \
\cb3           className="md:hidden flex items-center justify-between px-4 bg-white border-b border-gray-200 flex-shrink-0"\cb1 \
\cb3           style=\{\{ paddingTop: 'env(safe-area-inset-top)', minHeight: 'calc(env(safe-area-inset-top) + 56px)' \}\}\cb1 \
\cb3         >\cb1 \
\cb3           <button\cb1 \
\cb3             onClick=\{() => setSidebarOpen(true)\}\cb1 \
\cb3             className="relative z-40 p-2 rounded-lg hover:bg-gray-100 transition-colors"\cb1 \
\cb3             aria-label="Open menu"\cb1 \
\cb3           >\cb1 \
\cb3             <Menu size=\{24\} className="text-gray-700" />\cb1 \
\cb3           </button>\cb1 \
\cb3           <div className="text-lg font-semibold text-gray-900">\cb1 \
\cb3             \{clubSettings?.club_name || 'ARM'\}\cb1 \
\cb3           </div>\cb1 \
\cb3           <div className="w-10" />\cb1 \
\cb3         </header>\cb1 \
\
\cb3         \{/* Page content - THIS IS THE KEY SCROLL CONTAINER */\}\cb1 \
\cb3         <main className="flex-1 overflow-y-auto overscroll-contain p-4 md:p-6">\cb1 \
\cb3           <Outlet />\cb1 \
\cb3         </main>\cb1 \
\cb3       </div>\cb1 \
\cb3     </div>\cb1 \
\cb3   )\cb1 \
\cb3 \}\cb1 \
